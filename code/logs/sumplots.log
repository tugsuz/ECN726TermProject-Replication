
. 
. *******************************************************************************
. ***             Pre-war trade shares by country and industry                ***
. *******************************************************************************
. 
. *Read data
. u "$processed/data5" if t==0, clear

. 
. * change ind name for plot
. label define industry 8 "Misc", modify

. label define ind9 8 "Misc", modify

. replace ind9_str = "Misc" if ind9_str == "Miscellaneous"
(17,657 real changes made)

. 
. *Countries
. g iso = cty_iso

. drop country

. g country = partner_name

. 
. *Scale to billions, and annualize (ie turn 18-month into 12-month)
. replace v_wd = v_wd / 1000
(241,471 real changes made)

. replace v_wd = v_wd * (2/3)
(241,471 real changes made)

. 
. *Compute pre-war trade shares
. gcollapse (sum) sw_wd v_wd, by(country iso ind9_str)

. 
. *Reshape
. reshape wide sw_wd v_wd, i(country iso) j(ind) string
(j = Agriculture Apparel Chemicals Machinery Materials Metals Minerals Misc Transport)

Data                               Long   ->   Wide
-----------------------------------------------------------------------------
Number of observations              450   ->   50          
Number of variables                   5   ->   20          
j variable (9 values)          ind9_str   ->   (dropped)
xij variables:
                                  sw_wd   ->   sw_wdAgriculture sw_wdApparel ... sw_wdTransp
> ort
                                   v_wd   ->   v_wdAgriculture v_wdApparel ... v_wdTransport
-----------------------------------------------------------------------------

. 
. *Plot labels
. local I ""

. foreach v of varlist sw_wd* {
  2.         local i = subinstr("`v'","sw_wd","",.)
  3.         g `i' = `v'
  4.         drop `v'
  5.         local I "`I' `i'"
  6. }

. 
. *Shares by country-industry plot
. gsort iso

. preserve

.         keep if _n<=int(25)
(25 observations deleted)

.         graph bar `I', over(iso, label(angle(90)) sort(iso)) stack nolabel xsize(12) legen
> d(pos(11) row(1) size(vsmall)) title("") ylabel(,labsize(medsmall)) ///
>                 saving("$tmp/g1.gph", replace)
file /shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/data/tmp//g1.gph saved

. restore

. preserve

.         keep if _n>(25)
(25 observations deleted)

.         graph bar `I', over(iso, label(angle(90)) sort(iso)) stack nolabel xsize(12) legen
> d(pos(11) row(1)) title("")  ylabel(,labsize(medsmall)) ///
>                 saving("$tmp/g2.gph", replace)
file /shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/data/tmp//g2.gph saved

. restore

. cd "$tmp"
/shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/data/tmp

. grc1leg g1.gph g2.gph, row(2) pos(11)

. graph export "$results/appendix/fig_a1.pdf", replace
file
    /shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/results//appendix/fig_
    > a1.pdf saved as PDF format

. 
. 
. *******************************************************************************
. ***                        Box plots of tariff changes                      ***
. *******************************************************************************
. 
. *Read in data
. u "$processed/rf", clear

. 
. *Collapsetariffs by product-sector
. gcollapse dlz_usch dlz_chus dlz_usi dlz_chrw, by(hs6 ind9*)

. 
. *Replace zeros with missing
. foreach v of varlist dlz_usch dlz_chus dlz_usi dlz_chrw {
  2.         replace `v' = . if `v'==0
  3. }
(790 real changes made, 790 to missing)
(781 real changes made, 781 to missing)
(4,544 real changes made, 4,544 to missing)
(3,003 real changes made, 3,003 to missing)

. 
. *US Tariff Changes (Panel A)
. graph hbox dlz_usch dlz_usi, over(ind) noout ///
>         note("") ///
>         legend(order(1 "{&Delta}T(US,CH)" 2 "{&Delta}T(US,i)") pos(11) ring(0) row(2)) ///
>         yscale(range(-.3(.1).3)) ylabel(-.3(0.1).3) ///
>         yline(0, lpattern(dash) lcolor(red)) ///
>         medtype(marker) medmarker(m(s) mc(black) msize(small))

. graph export "$results/appendix/fig_a2_panelA.pdf", replace
file
    /shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/results//appendix/fig_
    > a2_panelA.pdf saved as PDF format

. 
. *China Tariff Changes (Panel B)
. graph hbox dlz_chus dlz_chrw, over(ind) noout ///
>         note("") ///
>         legend(order(1 "{&Delta}T(CH,US)" 2 "{&Delta}T(CH,i)") pos(11) ring(0) row(2)) ///
>         yscale(range(-.3(.1).3)) ylabel(-.3(0.1).3) ///
>         yline(0, lpattern(dash) lcolor(red)) ///
>         medtype(marker) medmarker(m(s) mc(black) msize(small)) 

. graph export "$results/appendix/fig_a2_panelB.pdf", replace
file
    /shared/share_amit-patrick/globaltradewar/GTW_replication_CHECK/results//appendix/fig_
    > a2_panelB.pdf saved as PDF format

. 
. exit

end of do-file

. 
end of do-file

