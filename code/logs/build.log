 67.         foreach v of varlist *_`country_str' {
 68.                 g `v'_lag = l.`v'
 69.                 g l`v' = log(`v')
 70.                 g dl`v' = d.l`v'
 71.                 g dl`v'_lag = l.dl`v'
 72.                 drop l`v'
 73.         }
 74.                 
.         la var v_`country_str' "Exports value to `country_str'" 
 75.         la var dlv_`country_str' "Change in log export value to `country_str'"
 76.         
.         destring hs6, replace
 77.         tempfile dests
 78.         save `dests', replace
 79.         
.         restore
 80. 
.         merge 1:1 cty_iso3 hs6 t using `dests', keep(master match) keepusing(v_* dlv_*)
 81.         drop _m
 82.         foreach v of varlist v_`country_str' dlv_`country_str' dlv_`country_str'_lag v_`country_str'_la
> g {
 83.                 replace `v' = . if cty_iso3 == "`d'"
 84.         }
 85. }
